                else:
                        raise TypeError("Arguments must be file paths or strings.")

        return text

def wtt(*args) -> None:
        if "VIRTUAL_ENV" not in os.environ:
                print("Virtual environment not set. Setting virtual environment.")
                os.system("python3 -m venv venv")
                os.system(". venv/bin/activate")

        if "google.generativeai" not in sys.modules:
                print("google.generativeai not installed. Installing google.generativeai.")
                os.system("pip install google-generativeai")

        if "GOOGLE_API_KEY" not in os.environ:
                print("GOOGLE_API_KEY not set. Setting GOOGLE_API_KEY from ~/.api-keys/gemini.")
                with open(os.path.expanduser("~/.api-keys/gemini"), "r") as file:
                        api_key = file.read()
                os.environ["GOOGLE_API_KEY"] = api_key

        if "." not in sys.path:
                print("Path variable not set. Adding . to path variable.")
                sys.path.append(".")

        prompt = arguments_to_text(*args)
        model = genai.GenerativeModel('gemini-pro')
        response = model.generate_content(prompt)
        print(response.text)

        with open("output", "a") as file:
                file.write(prompt)
                file.write(response.text)

if __name__ == "__main__":
        if len(sys.argv) < 2:
                print("Usage: python wtt.py <file_path_or_string> [<file_path_or_string> ...]")
                sys.exit(1)

        prompt_list = sys.argv[1:]
        wtt(*prompt_list)
